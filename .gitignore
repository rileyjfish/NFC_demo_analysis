# Ignore everything by default
*
!.gitignore
!.git/
!.github/

# Allow only journal_figures directory
!analysis/
!analysis/outputs/
!analysis/outputs/journal_figures/
!analysis/outputs/journal_figures/**

# Allow narrative directory but only LaTeX project files
!narrative/
narrative/*
!narrative/*.tex
!narrative/*.cls
!narrative/*.sty
!narrative/*.bib
!narrative/*.bbl
!narrative/*.blg
!narrative/Makefile
!narrative/README.md
!narrative/.latexmkrc
